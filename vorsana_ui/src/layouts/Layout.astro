---
/**
 * Main application layout.
 * Configures the document structure and initializes theme state (light/dark).
 */
import "../styles/global.css";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>

		<!-- Typography Integration -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap"
			rel="stylesheet"
		/>

		<script is:inline>
			/**
			 * Initializes the theme based on localStorage or system preference.
			 * Executes before page load to prevent FOUC (Flash of Unstyled Content).
			 */
			const theme = (() => {
				if (
					typeof localStorage !== "undefined" &&
					localStorage.getItem("theme")
				) {
					return localStorage.getItem("theme");
				}
				if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					return "dark";
				}
				return "light";
			})();

			if (theme === "dark") {
				document.documentElement.classList.add("dark");
			} else {
				document.documentElement.classList.remove("dark");
			}
		</script>
	</head>
	<body
		class="bg-stone-50 dark:bg-zinc-950 text-stone-800 dark:text-zinc-200 min-h-screen flex flex-col font-['Plus_Jakarta_Sans',sans-serif] antialiased transition-colors duration-300 selection:bg-emerald-200 dark:selection:bg-emerald-900 selection:text-stone-900 dark:selection:text-emerald-50"
	>
		<slot />
	</body>
</html>
